{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TTS More portable component package",
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": {"pattern": "(^[A-Za-z]:)|(^[/\\\\])|((^|[/\\\\])\\.\\.([/\\\\]|$))"}
    },
    "sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
    "revision": {"type": "string", "pattern": "^[0-9a-fA-F]{40,64}$"},
    "v1": {
      "type": "object",
      "required": [
        "schema_version", "component", "version", "build_id", "api_contract",
        "default_endpoint", "port", "launcher", "health_path", "capabilities",
        "model_profile", "runtime", "sha256_manifest"
      ],
      "properties": {
        "schema_version": {"const": 1},
        "component": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "build_id": {"type": "string", "minLength": 1},
        "api_contract": {"const": "tts-more-v1"},
        "default_endpoint": {"type": "string", "pattern": "^http://"},
        "port": {"type": "integer", "minimum": 1, "maximum": 65535},
        "launcher": {"$ref": "#/$defs/relativePath"},
        "health_path": {"const": "/health"},
        "capabilities": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "model_profile": {"type": "string", "minLength": 1},
        "runtime": {"$ref": "#/$defs/relativePath"},
        "sha256_manifest": {"$ref": "#/$defs/relativePath"}
      },
      "additionalProperties": false
    },
    "v2": {
      "type": "object",
      "required": [
        "schema_version", "component", "package_id", "release_version", "version", "build_id",
        "package_profile", "platform", "api_contract", "protocol", "source", "integration",
        "runtime", "models", "data_root", "data", "launchers", "endpoint", "capabilities",
        "sha256_manifest", "licenses"
      ],
      "properties": {
        "schema_version": {"const": 2},
        "component": {"enum": ["tts-more", "gpt-sovits", "indextts", "cosyvoice"]},
        "package_id": {"type": "string", "minLength": 1},
        "release_version": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "build_id": {"type": "string", "minLength": 1},
        "package_profile": {"enum": ["bootstrap", "full"]},
        "platform": {"const": "windows-x64"},
        "api_contract": {"const": "tts-more-v1"},
        "protocol": {
          "type": "object",
          "required": ["name", "version", "controller_range"],
          "properties": {
            "name": {"const": "tts-more-v1"},
            "version": {"type": "string", "minLength": 1},
            "controller_range": {"type": "string", "minLength": 1}
          },
          "additionalProperties": false
        },
        "source": {
          "type": "object",
          "required": ["repository", "revision"],
          "properties": {
            "repository": {"type": "string", "pattern": "^https://"},
            "revision": {"$ref": "#/$defs/revision"}
          },
          "additionalProperties": false
        },
        "integration": {
          "type": "object",
          "required": ["version", "source_revision", "bundle_sha256"],
          "properties": {
            "version": {"type": "string", "minLength": 1},
            "source_revision": {"$ref": "#/$defs/revision"},
            "bundle_sha256": {"$ref": "#/$defs/sha256"}
          },
          "additionalProperties": false
        },
        "runtime": {
          "type": "object",
          "required": ["python_version", "device_profiles", "lock", "state_path"],
          "properties": {
            "python_version": {"enum": ["3.10", "3.11"]},
            "device_profiles": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"enum": ["auto", "cu128", "cu126", "cpu"]}
            },
            "lock": {"$ref": "#/$defs/relativePath"},
            "state_path": {"$ref": "#/$defs/relativePath"}
          },
          "additionalProperties": false
        },
        "models": {
          "type": "object",
          "required": ["lock", "required"],
          "properties": {
            "lock": {"$ref": "#/$defs/relativePath"},
            "required": {"type": "boolean"}
          },
          "additionalProperties": false
        },
        "data_root": {"$ref": "#/$defs/relativePath"},
        "data": {
          "type": "object",
          "required": ["user", "local", "cache", "operations"],
          "properties": {
            "user": {"$ref": "#/$defs/relativePath"},
            "local": {"$ref": "#/$defs/relativePath"},
            "cache": {"$ref": "#/$defs/relativePath"},
            "operations": {"$ref": "#/$defs/relativePath"}
          },
          "additionalProperties": false
        },
        "launchers": {
          "type": "object",
          "required": ["initialize", "start", "stop", "repair", "build"],
          "properties": {
            "initialize": {"$ref": "#/$defs/relativePath"},
            "start": {"$ref": "#/$defs/relativePath"},
            "stop": {"$ref": "#/$defs/relativePath"},
            "repair": {"$ref": "#/$defs/relativePath"},
            "build": {"$ref": "#/$defs/relativePath"}
          },
          "additionalProperties": false
        },
        "endpoint": {
          "type": "object",
          "required": ["default_url", "port", "health_path", "capabilities_path", "bind_policy"],
          "properties": {
            "default_url": {"type": "string", "pattern": "^http://"},
            "port": {"type": "integer", "minimum": 1, "maximum": 65535},
            "health_path": {"type": "string", "minLength": 1, "pattern": "^/"},
            "capabilities_path": {"type": "string", "minLength": 1, "pattern": "^/"},
            "bind_policy": {"enum": ["loopback", "trusted-lan"]}
          },
          "additionalProperties": false
        },
        "capabilities": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "sha256_manifest": {"$ref": "#/$defs/relativePath"},
        "licenses": {"$ref": "#/$defs/relativePath"}
      },
      "additionalProperties": false
    }
  },
  "oneOf": [{"$ref": "#/$defs/v1"}, {"$ref": "#/$defs/v2"}]
}
